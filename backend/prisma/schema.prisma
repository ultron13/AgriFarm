generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  FARMER
  BUYER
  GOV_BUYER
  FIELD_AGENT
  LOGISTICS_COORDINATOR
  SALES_REP
  ADMIN
  SUPER_ADMIN
}

enum OrgType {
  COOPERATIVE
  RESTAURANT_GROUP
  HOTEL
  GOVERNMENT
  CORPORATE_CATERER
  INDIVIDUAL
}

enum Province {
  LIMPOPO
  MPUMALANGA
  GAUTENG
  NORTH_WEST
  FREE_STATE
  KWAZULU_NATAL
  WESTERN_CAPE
  EASTERN_CAPE
  NORTHERN_CAPE
}

enum BuyerType {
  RESTAURANT
  HOTEL
  CATERER
  GOVERNMENT_SCHOOL
  GOVERNMENT_HOSPITAL
  GOVERNMENT_CORRECTIONAL
  CORPORATE
  RETAILER
}

enum ProductCategory {
  VEGETABLES
  FRUIT
  HERBS
  LEGUMES
  ROOT_VEGETABLES
}

enum UnitType {
  KG
  UNIT
  CRATE
  PALLET
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD_OUT
  EXPIRED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  QUALITY_CHECKED
  IN_TRANSIT
  AT_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  DISPUTED
  CANCELLED
  REFUNDED
}

enum OrderSource {
  WEB
  WHATSAPP
  FIELD_AGENT
  API
}

enum QualityGrade {
  A
  B
  C
  REJECTED
}

enum DeliveryStatus {
  SCHEDULED
  COLLECTED
  AT_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum Corridor {
  LIMPOPO_GAUTENG
  MPUMALANGA_GAUTENG
  KZN_GAUTENG
  WESTERN_CAPE_GAUTENG
  EASTERN_CAPE_GAUTENG
  NORTHERN_CAPE_GAUTENG
  FREE_STATE_GAUTENG
  NORTH_WEST_GAUTENG
}

enum PaymentMethod {
  INSTANT_EFT
  ACCOUNT_TO_ACCOUNT
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  OVERDUE
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  farmer                 Farmer?
  buyer                  Buyer?
  qualityChecksPerformed QualityCheck[]

  @@index([email])
  @@index([phone])
  @@index([role])
}

model Organization {
  id                 String    @id @default(uuid())
  name               String
  type               OrgType
  bbeeeLevel         Int?
  bbeeeExpiry        DateTime?
  registrationNumber String?
  vatNumber          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  farmers   Farmer[]
  buyers    Buyer[]
  addresses Address[]
  documents Document[]
}

model Farmer {
  id             String        @id @default(uuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  displayName    String
  province       Province
  district       String
  gpsLat         Decimal?      @db.Decimal(10, 7)
  gpsLng         Decimal?      @db.Decimal(10, 7)
  bankAccountRef String? // PSP-tokenised reference; never the raw account number
  isSmallholder  Boolean       @default(false)
  ficaVerified   Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  listings        ProduceListing[]
  payouts         Payout[]
  qualityChecks   QualityCheck[]
  tenderBids      TenderBid[]
  complianceDocs  ComplianceDoc[]

  @@index([province])
  @@index([organizationId])
}

model Buyer {
  id                    String        @id @default(uuid())
  userId                String        @unique
  user                  User          @relation(fields: [userId], references: [id])
  organizationId        String?
  organization          Organization? @relation(fields: [organizationId], references: [id])
  displayName           String
  buyerType             BuyerType
  deliveryAddressId     String
  deliveryAddress       Address       @relation(fields: [deliveryAddressId], references: [id])
  preferredPaymentTerms Int           @default(7)
  creditLimit           Decimal?      @db.Decimal(12, 2)
  whatsappNumber        String?
  ficaVerified          Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?

  orders  Order[]
  tenders Tender[]

  @@index([buyerType])
}

model Address {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  line1          String
  line2          String?
  suburb         String
  city           String
  province       Province
  postalCode     String
  gpsLat         Decimal?      @db.Decimal(10, 7)
  gpsLng         Decimal?      @db.Decimal(10, 7)
  createdAt      DateTime      @default(now())

  buyers Buyer[]
}

model Document {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  type           String // "FICA_ID", "BBBEE_CERT", "BANK_PROOF", "TAX_CLEARANCE"
  r2Key          String // Cloudflare R2 object key
  filename       String
  verifiedAt     DateTime?
  verifiedById   String?
  createdAt      DateTime      @default(now())
}

model Product {
  id       String          @id @default(uuid())
  name     String
  category ProductCategory
  unitType UnitType        @default(KG)
  hsCode   String?

  listings ProduceListing[]
  grades   ProduceGrade[]
}

model ProduceGrade {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  grade         QualityGrade
  description   String
  minSizeG      Int?
  maxSizeG      Int?
  maxBlemishPct Decimal?     @db.Decimal(5, 2)

  listings ProduceListing[]
}

model ProduceListing {
  id             String        @id @default(uuid())
  farmerId       String
  farmer         Farmer        @relation(fields: [farmerId], references: [id])
  productId      String
  product        Product       @relation(fields: [productId], references: [id])
  gradeId        String?
  grade          ProduceGrade? @relation(fields: [gradeId], references: [id])
  farmGatePrice  Decimal       @db.Decimal(10, 2)
  availableKg    Decimal       @db.Decimal(10, 2)
  minimumOrderKg Decimal       @default(50) @db.Decimal(10, 2)
  availableFrom  DateTime
  availableUntil DateTime
  status         ListingStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  photos     ListingPhoto[]
  orderItems OrderItem[]

  @@index([status, availableFrom, availableUntil])
  @@index([farmerId])
  @@index([productId])
}

model ListingPhoto {
  id        String         @id @default(uuid())
  listingId String
  listing   ProduceListing @relation(fields: [listingId], references: [id])
  r2Key     String
  url       String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
}

model Order {
  id                   String      @id @default(uuid())
  orderNumber          String      @unique
  buyerId              String
  buyer                Buyer       @relation(fields: [buyerId], references: [id])
  status               OrderStatus @default(PENDING)
  deliveryDate         DateTime
  deliveryWindowStart  DateTime?
  deliveryWindowEnd    DateTime?
  totalFarmGateValue   Decimal     @db.Decimal(12, 2)
  buyerCommissionRate  Decimal     @default(0.08) @db.Decimal(5, 4)
  sellerCommissionRate Decimal     @default(0.05) @db.Decimal(5, 4)
  logisticsCharge      Decimal     @db.Decimal(12, 2)
  deliveredPrice       Decimal     @db.Decimal(12, 2)
  paymentTermDays      Int         @default(7)
  paymentDueDate       DateTime?
  notes                String?
  whatsappOrderRef     String?
  source               OrderSource @default(WEB)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  items         OrderItem[]
  delivery      Delivery?
  payment       Payment?
  invoice       Invoice?
  qualityChecks QualityCheck[]
  payouts       Payout[]

  @@index([status])
  @@index([buyerId])
  @@index([deliveryDate])
}

model OrderItem {
  id             String         @id @default(uuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id])
  listingId      String
  listing        ProduceListing @relation(fields: [listingId], references: [id])
  quantityKg     Decimal        @db.Decimal(10, 2)
  farmGatePrice  Decimal        @db.Decimal(10, 2)
  deliveredPrice Decimal        @db.Decimal(10, 2)
}

model QualityCheck {
  id           String       @id @default(uuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id])
  farmerId     String
  farmer       Farmer       @relation(fields: [farmerId], references: [id])
  fieldAgentId String
  fieldAgent   User         @relation(fields: [fieldAgentId], references: [id])
  gradeAwarded QualityGrade
  quantityKg   Decimal      @db.Decimal(10, 2)
  rejectedKg   Decimal      @default(0) @db.Decimal(10, 2)
  notes        String?
  performedAt  DateTime
  createdAt    DateTime     @default(now())

  photos QualityCheckPhoto[]
}

model QualityCheckPhoto {
  id             String       @id @default(uuid())
  qualityCheckId String
  qualityCheck   QualityCheck @relation(fields: [qualityCheckId], references: [id])
  r2Key          String
  url            String
  createdAt      DateTime     @default(now())
}

model LogisticsRoute {
  id             String   @id @default(uuid())
  name           String
  corridor       Corridor
  departureTime  String // "04:00"
  estimatedHours Int
  isActive       Boolean  @default(true)

  deliveries Delivery[]
}

model Delivery {
  id              String          @id @default(uuid())
  orderId         String          @unique
  order           Order           @relation(fields: [orderId], references: [id])
  routeId         String?
  route           LogisticsRoute? @relation(fields: [routeId], references: [id])
  status          DeliveryStatus  @default(SCHEDULED)
  vehicleRef      String?
  driverName      String?
  driverPhone     String?
  collectionAt    DateTime?
  hubArrivalAt    DateTime?
  deliveredAt     DateTime?
  trackingUrl     String?
  proofOfDelivery String? // R2 photo URL
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
}

model Payment {
  id           String        @id @default(uuid())
  orderId      String        @unique
  order        Order         @relation(fields: [orderId], references: [id])
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("ZAR")
  method       PaymentMethod
  pspReference String?
  status       PaymentStatus @default(PENDING)
  dueDate      DateTime
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

model Payout {
  id           String       @id @default(uuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id])
  farmerId     String
  farmer       Farmer       @relation(fields: [farmerId], references: [id])
  grossAmount  Decimal      @db.Decimal(12, 2)
  commission   Decimal      @db.Decimal(12, 2)
  netAmount    Decimal      @db.Decimal(12, 2)
  pspReference String?
  status       PayoutStatus @default(PENDING)
  scheduledFor DateTime
  paidAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, scheduledFor])
  @@index([farmerId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  buyerSnapshot Json
  lineItems     Json
  subtotal      Decimal       @db.Decimal(12, 2)
  vatAmount     Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  pdfUrl        String?
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  before       Json?
  after        Json?
  ip           String?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Farmer Compliance Vault ─────────────────────────────────────────────────

enum ComplianceDocType {
  BBBEE_CERTIFICATE
  TAX_CLEARANCE
  HACCP_CERTIFICATE
  FOOD_SAFETY_CERT
  COMPANY_REGISTRATION
  BANK_LETTER
}

enum ComplianceDocStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model ComplianceDoc {
  id             String              @id @default(uuid())
  farmerId       String
  farmer         Farmer              @relation(fields: [farmerId], references: [id])
  type           ComplianceDocType
  label          String
  fileUrl        String
  fileKey        String
  status         ComplianceDocStatus @default(PENDING)
  expiresAt      DateTime?
  uploadedAt     DateTime            @default(now())
  verifiedAt     DateTime?
  verifiedById   String?
  rejectionNote  String?

  @@unique([farmerId, type])
  @@index([farmerId])
  @@index([status])
}

// ─── Government / B2G Procurement ────────────────────────────────────────────

enum TenderStatus {
  OPEN
  EVALUATION
  AWARDED
  CANCELLED
}

enum BidStatus {
  SUBMITTED
  SHORTLISTED
  AWARDED
  REJECTED
}

model Tender {
  id               String       @id @default(uuid())
  referenceNumber  String       @unique
  buyerId          String
  buyer            Buyer        @relation(fields: [buyerId], references: [id])
  title            String
  description      String
  department       String
  productCategory  String
  quantityKg       Decimal      @db.Decimal(12, 2)
  deliveryDate     DateTime
  deliveryProvince Province
  deliveryAddress  String
  budgetPerKg      Decimal?     @db.Decimal(10, 2)
  status           TenderStatus @default(OPEN)
  closingDate      DateTime
  requiresBbbee    Boolean      @default(true)
  requiresHaccp    Boolean      @default(false)
  requiresTaxClear Boolean      @default(true)
  awardedBidId     String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  bids TenderBid[]

  @@index([status])
  @@index([buyerId])
}

model TenderBid {
  id             String    @id @default(uuid())
  tenderId       String
  tender         Tender    @relation(fields: [tenderId], references: [id])
  farmerId       String
  farmer         Farmer    @relation(fields: [farmerId], references: [id])
  pricePerKg     Decimal   @db.Decimal(10, 2)
  quantityKg     Decimal   @db.Decimal(12, 2)
  notes          String?
  status         BidStatus @default(SUBMITTED)
  complianceDocs Json      @default("[]")
  submittedAt    DateTime  @default(now())
  evaluatedAt    DateTime?

  @@unique([tenderId, farmerId])
  @@index([tenderId])
  @@index([farmerId])
}
