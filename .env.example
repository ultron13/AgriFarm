# Database
DATABASE_URL=postgresql://farmconnect:farmconnect@localhost:5432/farmconnect_dev

# Auth
JWT_SECRET=change-me-minimum-32-chars-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Ozow (buyer instant EFT)
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_WEBHOOK_SECRET=
OZOW_IS_TEST=true

# Stitch (account-to-account & farmer payouts)
STITCH_CLIENT_ID=
STITCH_CLIENT_SECRET=
STITCH_WEBHOOK_SECRET=

# Clickatell (WhatsApp / SMS)
CLICKATELL_API_KEY=
CLICKATELL_WHATSAPP_NUMBER=

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@farmconnect.co.za
SENDGRID_FROM_NAME=FarmConnect SA

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=farmconnect-dev
R2_PUBLIC_URL=https://assets.farmconnect.co.za

# Sentry (production error tracking)
SENTRY_DSN=
